{
	"name": "stanley",
	"version": "1.0.0",
	"description": "Turns Obsidian into Stanley",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint .",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"keywords": [],
	"license": "0-BSD",
	"author": "mattsclimate",
	"repository": "https://github.com/mattsclimate/Obsidian-Plugin-Stanley",
	"devDependencies": {
		"@eslint/js": "9.30.1",
		"@types/node": "^22.0.0",
		"@vitest/coverage-v8": "^4.1.4",
		"esbuild": "0.25.5",
		"eslint-plugin-obsidianmd": "0.1.9",
		"globals": "14.0.0",
		"jiti": "2.6.1",
		"jsdom": "^29.0.2",
		"tslib": "2.4.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "8.35.1",
		"vitest": "^4.1.4"
	},
	"dependencies": {
		"obsidian": "latest"
	}
